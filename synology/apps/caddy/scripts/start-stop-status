#!/bin/sh
set -eu

PACKAGE_ROOT="${SYNOPKG_PKGDEST}/app"
CONFIG_DIR="${SYNOPKG_PKGVAR}/config"
RUN_DIR="${SYNOPKG_PKGVAR}/run"
LOG_DIR="${SYNOPKG_PKGVAR}/log"
PID_FILE="${RUN_DIR}/caddy.pid"
LOG_FILE="${LOG_DIR}/caddy.log"
CADDY_BIN="${PACKAGE_ROOT}/bin/caddy"
CADDYFILE="${CONFIG_DIR}/Caddyfile"
WWW_DIR="${CONFIG_DIR}/www"

is_running() {
  [ -f "$PID_FILE" ] || return 1
  PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  [ -n "$PID" ] || return 1
  kill -0 "$PID" 2>/dev/null
}

ensure_config() {
  mkdir -p "$CONFIG_DIR" "$RUN_DIR" "$LOG_DIR" "$WWW_DIR" "${CONFIG_DIR}/caddy-data" "${CONFIG_DIR}/caddy-config"

  if [ ! -f "$WWW_DIR/index.html" ]; then
    cat >"$WWW_DIR/index.html" <<EOF
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Caddy on Synology</title>
</head>
<body>
  <h1>Caddy is running</h1>
  <p>Edit <code>${CADDYFILE}</code> to configure reverse proxies, sites, and TLS.</p>
</body>
</html>
EOF
  fi

  if [ ! -f "$CADDYFILE" ]; then
    cat >"$CADDYFILE" <<EOF
:20180 {
    root * ${WWW_DIR}
    file_server
}
EOF
  fi
}

start_manual() {
  ensure_config
  export HOME="${CONFIG_DIR}"
  export XDG_DATA_HOME="${CONFIG_DIR}/caddy-data"
  export XDG_CONFIG_HOME="${CONFIG_DIR}/caddy-config"
  nohup "$CADDY_BIN" run --config "$CADDYFILE" --adapter caddyfile >>"$LOG_FILE" 2>&1 &
  echo "$!" >"$PID_FILE"

  sleep 2
  if ! is_running; then
    rm -f "$PID_FILE"
    exit 1
  fi
}

stop_manual() {
  if ! is_running; then
    rm -f "$PID_FILE"
    exit 0
  fi

  kill "$(cat "$PID_FILE")"
  rm -f "$PID_FILE"
}

status_manual() {
  if is_running; then
    return 0
  fi

  rm -f "$PID_FILE"
  return 1
}

case "${1:-}" in
  start)
    if status_manual; then
      exit 0
    fi
    start_manual
    ;;
  stop)
    stop_manual
    ;;
  status)
    if status_manual; then
      exit 0
    fi
    exit 1
    ;;
  restart)
    "$0" stop || true
    "$0" start
    ;;
  *)
    echo "Usage: $0 {start|stop|status|restart}" >&2
    exit 1
    ;;
esac
