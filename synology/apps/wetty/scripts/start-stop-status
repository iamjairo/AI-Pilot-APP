#!/bin/sh
set -eu

PACKAGE_ROOT="${SYNOPKG_PKGDEST}/app"
CONFIG_DIR="${SYNOPKG_PKGVAR}/config"
RUN_DIR="${SYNOPKG_PKGVAR}/run"
LOG_DIR="${SYNOPKG_PKGVAR}/log"
PID_FILE="${RUN_DIR}/wetty.pid"
LOG_FILE="${LOG_DIR}/wetty.log"
ENV_FILE="${CONFIG_DIR}/wetty.env"
WETTY_MAIN="${PACKAGE_ROOT}/wetty/build/main.js"

find_node_bin() {
  for candidate in \
    /var/packages/Node.js_v20/target/usr/local/bin/node \
    /volume1/@appstore/Node.js_v20/usr/local/bin/node \
    /usr/local/bin/node \
    /bin/node
  do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

is_running() {
  [ -f "$PID_FILE" ] || return 1
  PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  [ -n "$PID" ] || return 1
  kill -0 "$PID" 2>/dev/null
}

ensure_config() {
  mkdir -p "$CONFIG_DIR" "$RUN_DIR" "$LOG_DIR"

  if [ ! -f "$ENV_FILE" ]; then
    cat >"$ENV_FILE" <<EOF
WETTY_HOST=0.0.0.0
WETTY_PORT=3000
WETTY_BASE=/
WETTY_TITLE=Synology Terminal
WETTY_COMMAND=/bin/sh
EOF
  fi
}

start_manual() {
  ensure_config
  NODE_BIN="$(find_node_bin)"
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  export HOME="${CONFIG_DIR}"
  nohup "$NODE_BIN" "$WETTY_MAIN" \
    --host "${WETTY_HOST:-0.0.0.0}" \
    --port "${WETTY_PORT:-3000}" \
    --base "${WETTY_BASE:-/}" \
    --title "${WETTY_TITLE:-Synology Terminal}" \
    --command "${WETTY_COMMAND:-/bin/sh}" \
    >>"$LOG_FILE" 2>&1 &
  echo "$!" >"$PID_FILE"

  sleep 2
  if ! is_running; then
    rm -f "$PID_FILE"
    exit 1
  fi
}

stop_manual() {
  if ! is_running; then
    rm -f "$PID_FILE"
    exit 0
  fi

  kill "$(cat "$PID_FILE")"
  rm -f "$PID_FILE"
}

status_manual() {
  if is_running; then
    return 0
  fi

  rm -f "$PID_FILE"
  return 1
}

case "${1:-}" in
  start)
    if status_manual; then
      exit 0
    fi
    start_manual
    ;;
  stop)
    stop_manual
    ;;
  status)
    if status_manual; then
      exit 0
    fi
    exit 1
    ;;
  restart)
    "$0" stop || true
    "$0" start
    ;;
  *)
    echo "Usage: $0 {start|stop|status|restart}" >&2
    exit 1
    ;;
esac
