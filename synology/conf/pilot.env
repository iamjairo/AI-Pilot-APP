# Pilot Synology backend environment
# Copy this file to the package var/config directory on install.
#
# Override the default HTTPS companion port if needed.
# PILOT_COMPANION_PORT=18088
#
# Force HTTP instead of HTTPS only if your reverse proxy terminates TLS.
# PILOT_COMPANION_PROTOCOL=https
#
# Auto-start the backend companion service when DSM starts the package.
# PILOT_COMPANION_AUTO_START=true
