{
  "name": "pilot",
  "version": "0.0.0",
  "description": "Your cockpit for AI-powered coding",
  "main": "out/main/index.js",
  "author": "Espen Nilsen <hi@e9n.dev>",
  "license": "MIT",
  "scripts": {
    "dev": "vite build -c vite.companion.mjs && electron-vite dev --config electron-vite.config.mjs",
    "dev:trace": "vite build -c vite.companion.mjs && NODE_OPTIONS='--trace-warnings' electron-vite dev --config electron-vite.config.mjs",
    "build": "electron-vite build --config electron-vite.config.mjs",
    "build:backend": "vite build -c vite.backend.config.mjs",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:spk": "npm run build && npm run build:backend && node ./scripts/build-synology-spk.mjs --app pilot",
    "build:spk:caddy": "node ./scripts/build-synology-spk.mjs --app caddy",
    "build:spk:code-server": "node ./scripts/build-synology-spk.mjs --app code-server",
    "build:spk:wetty": "node ./scripts/build-synology-spk.mjs --app wetty",
    "build:spk:all": "npm run build:spk && npm run build:spk:caddy && npm run build:spk:code-server && npm run build:spk:wetty",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npx eslint . --ext .ts,.tsx,.js,.jsx --format stylish --max-warnings 0 --report-unused-disable-directives --ignore-pattern \"dist/**\" --ignore-pattern \"out/**\" --ignore-pattern \"node_modules/**\" --ignore-pattern \".webpack/**\" --ignore-pattern \"*.config.{js,ts}\"",
    "preview": "electron-vite preview --config electron-vite.config.mjs",
    "postinstall": "node -e \"if (process.platform === 'darwin') { try { require('child_process').execSync('chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper', { stdio: 'ignore' }) } catch (e) {} }\""
  },
  "dependencies": {
    "@homebridge/ciao": "^1.3.6",
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "chokidar": "^5.0.0",
    "diff": "^8.0.3",
    "dockerode": "^5.0.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "ignore": "^7.0.5",
    "lucide-react": "^0.577.0",
    "node-forge": "^1.4.0",
    "node-pty": "^1.1.0",
    "ollama": "^0.6.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "simple-git": "^3.36.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12",
    "express-rate-limit": "^8.3.2"
  },
  "devDependencies": {
    "@swc/core": "^1.15.30",
    "@tailwindcss/vite": "^4.2.2",
    "@types/adm-zip": "^0.5.8",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sharp": "^0.32.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.5.0",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
